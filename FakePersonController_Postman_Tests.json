    {
      "name": "4. /api/person – specifikt",
      "item": [
        {
          "name": "T8-T9: Alle felter eksisterer, er ikke null, og har korrekte typer",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/person"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "// T8: Alle forventede top-level felter eksisterer",
                  "pm.test('T8: Response indeholder alle forventede felter', function () {",
                  "    const topFields = ['cpr', 'firstName', 'lastName', 'gender', 'dateOfBirth', 'address', 'phoneNumber'];",
                  "    topFields.forEach(function (field) {",
                  "        pm.expect(json, 'Mangler felt: ' + field).to.have.property(field);",
                  "    });",
                  "});",
                  "",
                  "// T9a: Ingen string-felter er null eller tomme",
                  "pm.test('T9a: Ingen string-felter er null eller tomme', function () {",
                  "    const stringFields = ['cpr', 'firstName', 'lastName', 'gender', 'dateOfBirth', 'phoneNumber'];",
                  "    stringFields.forEach(function (field) {",
                  "        pm.expect(json[field], field + ' er null/tom').to.be.a('string').and.not.be.empty;",
                  "    });",
                  "});",
                  "",
                  "// T9b: address er et objekt med forventede underfelter",
                  "pm.test('T9b: address er et objekt med street, number, postalCode, townName', function () {",
                  "    pm.expect(json.address).to.be.an('object');",
                  "    const addrFields = ['street', 'number', 'postalCode', 'townName'];",
                  "    addrFields.forEach(function (field) {",
                  "        pm.expect(json.address, 'address mangler: ' + field).to.have.property(field);",
                  "        pm.expect(json.address[field], 'address.' + field + ' er null/tom').to.not.be.null;",
                  "    });",
                  "});",
                  "",
                  "// T9c: gender er enten 'male' eller 'female'",
                  "pm.test('T9c: gender er male eller female', function () {",
                  "    pm.expect(json.gender).to.be.oneOf(['male', 'female']);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
