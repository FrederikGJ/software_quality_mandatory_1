    {
      "name": "2. /api/cpr – specifikt",
      "item": [
        {
          "name": "T4-T5: CPR nøgle, værdi og format",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/cpr"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "// T4: Nøglen 'cpr' eksisterer",
                  "pm.test('T4: Response indeholder nøglen cpr', function () {",
                  "    pm.expect(json).to.have.property('cpr');",
                  "});",
                  "",
                  "// T5: CPR er en ikke-tom streng med korrekt format (DDMMYYXXXX)",
                  "pm.test('T5: CPR-værdi er en ikke-tom streng i format DDMMYYXXXX', function () {",
                  "    pm.expect(json.cpr).to.be.a('string').and.not.be.empty;",
                  "    pm.expect(json.cpr).to.match(/^\\d{6}\\d{4}$/);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
