        {
          "name": "T6-T7: phoneNumber nøgle, værdi og format",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/phone"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "// T6: Nøglen 'phoneNumber' eksisterer",
                  "pm.test('T6: Response indeholder nøglen phoneNumber', function () {",
                  "    pm.expect(json).to.have.property('phoneNumber');",
                  "});",
                  "",
                  "// T7: Telefonnummer er en ikke-tom streng med 8 cifre",
                  "pm.test('T7: phoneNumber er en streng med 8 cifre', function () {",
                  "    pm.expect(json.phoneNumber).to.be.a('string').and.not.be.empty;",
                  "    pm.expect(json.phoneNumber).to.match(/^\\d{8}$/);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
